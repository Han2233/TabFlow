{
  "manifest_version": 3,
  "name": "TabFlow",
  "description": "智能标签页管理工具 - 分组、搜索、快照、AI整理",
  "version": "0.1.0",
  "permissions": [
    "tabs",
    "tabGroups",
    "sidePanel",
    "storage",
    "favicon"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "TabFlow",
    "default_popup": "src/popup/index.html"
  },
  "commands": {
    "open_side_panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "打开/关闭侧边栏面板"
    },
    "search_tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "搜索标签页"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
