{
  "manifest_version": 3,
  "name": "TabFlow",
  "description": "智能标签页管理工具 - 分组、搜索、快照、AI整理",
  "version": "0.1.0",
  "permissions": [
    "tabs",
    "tabGroups",
    "sidePanel",
    "storage",
    "favicon"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "TabFlow"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
